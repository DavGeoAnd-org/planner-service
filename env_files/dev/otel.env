# otel general
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev,service.framework=javalin,service.namespace=planner
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-service:4318
OTEL_RESOURCE_DISABLED_KEYS=host.arch,os.description,os.type,os.version,process.command_args,process.command_line,process.executable.path,process.pid,process.runtime.description,process.runtime.name,aws.ecs.cluster.arn,aws.ecs.container.arn,aws.ecs.container.image.id,aws.ecs.task.arn,aws.log.group.arns,aws.log.group.names,aws.log.stream.arns,aws.log.stream.names,cloud.resource_id
OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=4095
OTEL_INSTRUMENTATION_MICROMETER_ENABLED=true

# otel metrics
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_METRICS_DEFAULT_HISTOGRAM_AGGREGATION=BASE2_EXPONENTIAL_BUCKET_HISTOGRAM
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=DELTA

# otel logs
OTEL_LOGS_EXPORTER=otlp

# otel traces
OTEL_TRACES_EXPORTER=otlp