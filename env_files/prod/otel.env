# otel general
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,service.framework=javalin,service.namespace=planner
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_RESOURCE_DISABLED_KEYS=host.arch,os.description,os.type,os.version,process.command_args,process.command_line,process.executable.path,process.pid,process.runtime.description,process.runtime.name,aws.ecs.cluster.arn,aws.ecs.container.arn,aws.ecs.container.image.id,aws.ecs.task.arn,aws.log.group.arns,aws.log.group.names,aws.log.stream.arns,aws.log.stream.names,cloud.resource_id
OTEL_RESOURCE_PROVIDERS_AWS_ENABLED=true

# otel metrics
OTEL_METRICS_EXPORTER=otlp

# otel logs
OTEL_LOGS_EXPORTER=otlp

# otel traces
OTEL_TRACES_EXPORTER=otlp